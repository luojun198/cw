{
  "name": "cw-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../scripts/generate-build-info.cjs --dev",
    "dev": "vite --host 0.0.0.0 --port 5175",
    "build": "vue-tsc -b && vite build",
    "build:deploy": "node ../scripts/generate-build-info.cjs && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "echarts": "^6.0.0",
    "element-plus": "^2.6.1",
    "exceljs": "^4.4.0",
    "pinia": "^2.1.7",
    "print-js": "^1.6.0",
    "vue": "^3.4.21",
    "vue-plugin-hiprint": "^0.0.60",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/ui": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "playwright": "^1.59.1",
    "typescript": "^5.4.2",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.6",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.0.6"
