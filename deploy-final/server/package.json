{
  "name": "cw-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": "dist/bundle.cjs",
  "scripts": {
    "dev": "cross-env SCHEMA_DIR=src/db node --watch --import tsx/esm src/index.ts",
    "build": "tsc",
    "build:bundle": "node scripts/buildBundle.mjs",
    "start": "node dist/bundle.cjs",
    "db:init": "cross-env SCHEMA_DIR=src/db node --import tsx/esm src/scripts/initDb.ts",
    "db:seed": "node --import tsx/esm src/scripts/seedAccounts.ts",
    "db:migrate": "node --import tsx/esm src/scripts/runMigrations.ts up",
    "db:migrate:rollback": "node --import tsx/esm src/scripts/runMigrations.ts down",
    "db:migrate:status": "node --import tsx/esm src/scripts/runMigrations.ts status",
    "db:import:acd": "node --import tsx/esm src/scripts/importAcdToCurrentAccountSet.ts",
    "db:migrate:transfer": "node --import tsx/esm src/scripts/migrateTransferConfig.ts",
    "config:ai": "node --import tsx/esm src/scripts/configThirdPartyAi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ai": "node --import tsx/esm src/scripts/testThirdPartyAi.ts",
    "test:services": "node --import tsx/esm scripts/run-service-tests.ts",
    "pkg:build": "node scripts/buildBundle.mjs && npx pkg dist/bundle.cjs --targets node18-win-x64 --output dist/cw-finance.exe"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "@vitest/ui": "^4.1.4",
    "cross-env": "^7.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^4.1.4"
  },
  "pkg": {
    "assets": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "client/dist/**/*"
    ]
  }
}
